# Square API Configuration
# Get these from https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=
SQUARE_APP_ID=
SQUARE_LOCATION_ID=

# Set to 'production' when ready to go live, 'sandbox' for testing
SQUARE_ENV=sandbox

# Public Variables (exposed to browser)
NEXT_PUBLIC_SQUARE_APP_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=

# Your live domain
NEXT_PUBLIC_SITE_URL=https://sacredportalwellness.com

# Environment
NODE_ENV=development
